---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'waxlashtan.com — The definitive domain for waxing, lashes, and tanning.', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href.replace(/\/$/, '') || String(Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Google Site Verification -->
    <meta name="google-site-verification" content="J6nFpQgAidyR7S0a6k9NNgOgl5nmdwO4dJhkOl7VxQE" />

    <!-- Preconnect to CDN -->
    <link rel="preconnect" href="https://imagedelivery.net" />

    <title>{title}</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&amp;family=Playfair+Display:wght@700&amp;display=swap" rel="stylesheet" />

    <slot name="head" />
  </head>
  <body class="bg-[#F8F1E9] text-[#2D2D2D] antialiased overflow-x-hidden">
    <!-- Navigation -->
    <nav class="bg-white/95 backdrop-blur-md border-b border-[#EDE4D7] sticky top-0 z-50" id="navbar">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-16 md:h-20 gap-3">
          <div class="flex items-center gap-x-2 sm:gap-x-3 min-w-0">
            <div class="flex items-center gap-x-1.5 sm:gap-x-2 min-w-0">
              <div class="w-8 h-8 sm:w-9 sm:h-9 bg-[#B85C38] rounded-xl flex items-center justify-center shrink-0">
                <span class="text-white text-lg sm:text-2xl font-bold tracking-tighter">WLT</span>
              </div>
              <div class="truncate">
                <span class="font-semibold text-lg sm:text-2xl tracking-tight">waxlashtan</span>
                <span class="font-semibold text-lg sm:text-2xl tracking-tight text-[#B85C38]">.com</span>
              </div>
            </div>
          </div>

          <div class="flex items-center gap-x-2 sm:gap-x-4 shrink-0">
            <a href="#why" class="hidden md:block px-4 py-2 text-sm font-medium text-[#4A5D4A] hover:text-[#2D2D2D] transition-colors">Why This Domain</a>
            <a href="#seo" class="hidden md:block px-4 py-2 text-sm font-medium text-[#4A5D4A] hover:text-[#2D2D2D] transition-colors">SEO &amp; Market Fit</a>
            <a href="#use-cases" class="hidden md:block px-4 py-2 text-sm font-medium text-[#4A5D4A] hover:text-[#2D2D2D] transition-colors">Use Cases</a>

            <a href="#acquire"
               class="inline-flex items-center justify-center px-4 sm:px-6 py-2 sm:py-2.5 bg-[#B85C38] hover:bg-[#A04E30] text-white text-xs sm:text-sm font-semibold rounded-2xl transition-all active:scale-[0.985] whitespace-nowrap">
              Make an Offer
            </a>
          </div>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-[#EDE4D7]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-10">
        <!-- Domain Acquisition CTA -->
        <div class="bg-gradient-to-r from-[#2D2D2D] via-[#3A3A3A] to-[#2D2D2D] rounded-2xl p-8 md:p-10 mb-8 text-center border border-[#4A4A4A]">
          <div class="inline-block px-4 py-1 bg-white/10 rounded-full text-xs font-medium tracking-wider text-white/70 mb-4">
            PREMIUM DOMAIN AVAILABLE
          </div>
          <h3 class="text-2xl md:text-3xl font-bold text-white mb-3">
            Acquire waxlashtan.com
          </h3>
          <p class="text-white/60 max-w-lg mx-auto mb-6">
            A rare, service-exclusive premium domain with SEO built directly into the name.
            Own the definitive digital identity for the wax, lash, and tan market.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
            <a
              href="mailto:sales@desertrich.com?subject=Acquisition%20Inquiry%20-%20waxlashtan.com"
              class="inline-flex items-center justify-center gap-x-2 px-8 py-3 bg-[#B85C38] hover:bg-[#A04E30] text-white font-semibold rounded-xl transition-all"
            >
              <span>Inquire: sales@desertrich.com</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </a>
            <button
              id="copyEmailBtn"
              class="inline-flex items-center justify-center gap-x-2 px-6 py-3 border border-white/20 hover:bg-white/5 text-white font-medium rounded-xl transition-all text-sm"
              onclick="copyEmail()"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
              Copy Email
            </button>
          </div>
          <p class="mt-6 text-xs text-white/40">
            Serious inquiries only. This domain is matched exclusively to a specific, high-demand service combination.
          </p>
        </div>

        <!-- Bottom: Disclaimer + Info -->
        <div class="border-t border-[#EDE4D7] pt-8">
          <p class="text-xs text-[#9B9B9B] mb-6 leading-relaxed max-w-3xl">
            <strong>Disclaimer:</strong> This website is for demonstration and informational purposes only. It does not constitute an offer of services,
            a commitment to deploy, or a guarantee of outcomes. All statistics, projections, and references to specific
            technologies are based on publicly available information as of June 2026 and are subject to change.
          </p>
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-y-2 text-xs text-[#9B9B9B]">
            <div>
              <p>© 2026 waxlashtan.com &mdash; A premium domain available for acquisition.</p>
            </div>
            <div class="flex items-center gap-x-4">
              <span>Exact service match</span>
              <span class="hidden md:inline">&bull;</span>
              <span>High acquisition value</span>
              <span class="hidden md:inline">&bull;</span>
              <span>Premium .com</span>
            </div>
          </div>
        </div>
      </div>
    </footer>

    <script>
      function copyEmail() {
        const email = 'sales@desertrich.com';
        navigator.clipboard.writeText(email).then(() => {
          const btn = document.getElementById('copyEmailBtn');
          if (btn) {
            const original = btn.innerHTML;
            btn.innerHTML = '<span>Copied to clipboard!</span>';
            btn.classList.add('bg-green-600', 'border-green-500');
            setTimeout(() => {
              btn.innerHTML = original;
              btn.classList.remove('bg-green-600', 'border-green-500');
            }, 2200);
          }
        }).catch(() => {
          window.location.href = 'mailto:' + email;
        });
      }

      // Sticky nav shadow on scroll
      window.addEventListener('scroll', () => {
        const nav = document.getElementById('navbar');
        if (nav) {
          if (window.scrollY > 20) {
            nav.classList.add('shadow-sm');
          } else {
            nav.classList.remove('shadow-sm');
          }
        }
      });

      console.log('%c[waxlashtan.com] Definitive service-matched premium landing page ready.', 'color:#B85C38');
    </script>
  </body>
</html>
